<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-7xl mx-auto">
  <div class="text-center mb-14">
    <p class="text-neon font-mono text-xs tracking-widest mb-2">◈ THE TEAM</p>
    <h1 class="font-display font-black text-white text-4xl mb-3">CLUB MEMBERS</h1>
    <p class="text-gray-500 max-w-xl mx-auto">The passionate people building Technophiles — organising events, running workshops, and growing the community.</p>
  </div>

  <%
    const categories = [
      { key: 'faculty', label: 'Faculty Advisors', icon: '🎓' },
      { key: 'core', label: 'Core Team', icon: '⭐' },
      { key: 'technical', label: 'Technical Team', icon: '💻' },
      { key: 'creative', label: 'Creative Team', icon: '🎨' },
      { key: 'management', label: 'Management Team', icon: '📋' },
      { key: 'alumni', label: 'Alumni', icon: '🏆' },
    ];
  %>

  <% categories.forEach(cat => { %>
  <% if (grouped[cat.key] && grouped[cat.key].length > 0) { %>
  <section class="mb-14">
    <div class="flex items-center gap-4 mb-8">
      <span class="text-2xl"><%= cat.icon %></span>
      <h2 class="font-display font-bold text-white text-xl tracking-wide"><%= cat.label.toUpperCase() %></h2>
      <div class="flex-1 h-px bg-dark-border"></div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-5">
      <% grouped[cat.key].forEach(member => { %>
      <div class="card p-5 text-center group hover:border-neon/30 transition-all">
        <div class="relative inline-block mb-3">
          <img src="<%= member.image %>" alt="<%= member.name %>" class="w-20 h-20 rounded-full object-cover mx-auto border-2 border-dark-border group-hover:border-neon/40 transition-all" onerror="this.src='/images/default-avatar.png'">
          <% if (cat.key === 'core') { %>
          <div class="absolute -bottom-1 -right-1 w-5 h-5 rounded-full bg-neon flex items-center justify-center text-black text-xs">⭐</div>
          <% } %>
        </div>
        <p class="text-white font-bold text-sm leading-tight"><%= member.name %></p>
        <p class="text-neon text-xs font-mono mt-1"><%= member.post %></p>
        <% if (member.department || member.year) { %>
        <p class="text-gray-600 text-xs mt-1"><%= member.department %> <%= member.year ? '· '+ member.year : '' %></p>
        <% } %>
        <% if (member.batch) { %><p class="text-gray-600 text-xs"><%= member.batch %></p><% } %>
        <!-- Social links -->
        <div class="flex justify-center gap-2 mt-3">
          <% if (member.github) { %>
          <a href="<%= member.github %>" target="_blank" class="w-6 h-6 flex items-center justify-center border border-dark-border rounded hover:border-neon hover:text-neon text-gray-500 transition-all text-xs">GH</a>
          <% } %>
          <% if (member.linkedin) { %>
          <a href="<%= member.linkedin %>" target="_blank" class="w-6 h-6 flex items-center justify-center border border-dark-border rounded hover:border-neon hover:text-neon text-gray-500 transition-all text-xs">in</a>
          <% } %>
          <% if (member.instagram) { %>
          <a href="<%= member.instagram %>" target="_blank" class="w-6 h-6 flex items-center justify-center border border-dark-border rounded hover:border-neon hover:text-neon text-gray-500 transition-all text-xs">ig</a>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </section>
  <% } %>
  <% }) %>

  <% if (members.length === 0) { %>
  <div class="text-center py-20 card"><p class="text-4xl mb-4">👥</p><p class="text-gray-400">Team members coming soon!</p></div>
  <% } %>

  <% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
  <div class="fixed bottom-6 right-6"><a href="/members/admin" class="btn-neon-solid text-sm px-5 py-3 shadow-neon">⚙ MANAGE MEMBERS</a></div>
  <% } %>
</main>
<%- include('../partials/footer') %>
