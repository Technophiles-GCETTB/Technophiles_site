<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-2xl mx-auto">
  <div class="mb-6"><a href="/members/admin" class="text-gray-500 text-sm hover:text-neon font-mono">← BACK</a></div>
  <div class="card p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
    <h1 class="font-display font-bold text-white text-2xl tracking-widest mb-8"><%= member?._id ? 'EDIT MEMBER' : 'ADD MEMBER' %></h1>
    <% if (typeof error !== 'undefined' && error) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded text-sm mb-6">⚠ <%= error %></div><% } %>
    <form action="<%= member?._id ? '/members/'+member._id+'?_method=PUT' : '/members' %>" method="POST" class="space-y-5">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">FULL NAME *</label>
          <input type="text" name="name" required value="<%= member?.name||'' %>" placeholder="Rahul Sharma" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">POST / ROLE *</label>
          <input type="text" name="post" required value="<%= member?.post||'' %>" placeholder="President, Core Member..." class="input-dark text-sm" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DEPARTMENT</label>
          <input type="text" name="department" value="<%= member?.department||'' %>" placeholder="CSE / ECE..." class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">YEAR / BATCH</label>
          <input type="text" name="year" value="<%= member?.year||'' %>" placeholder="3rd Year" class="input-dark text-sm" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">PROFILE PHOTO URL</label>
        <input type="url" name="image" value="<%= member?.image||'' %>" placeholder="https://... or /images/..." class="input-dark text-sm" />
        <p class="text-xs text-gray-600 mt-1">Paste a direct image URL (Google Drive, Imgur, etc.)</p>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">BIO</label>
        <textarea name="bio" rows="2" placeholder="Short description..." class="input-dark text-sm resize-none"><%= member?.bio||'' %></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">CATEGORY</label>
          <select name="category" class="input-dark text-sm">
            <% ['core','technical','creative','management','faculty','alumni'].forEach(c => { %>
            <option value="<%= c %>" <%= member?.category===c?'selected':'' %>><%= c.toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DISPLAY ORDER</label>
          <input type="number" name="order" value="<%= member?.order||99 %>" min="1" class="input-dark text-sm" />
        </div>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">GITHUB URL</label>
          <input type="url" name="github" value="<%= member?.github||'' %>" placeholder="https://github.com/..." class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">LINKEDIN URL</label>
          <input type="url" name="linkedin" value="<%= member?.linkedin||'' %>" placeholder="https://linkedin.com/in/..." class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">INSTAGRAM URL</label>
          <input type="url" name="instagram" value="<%= member?.instagram||'' %>" placeholder="https://instagram.com/..." class="input-dark text-sm" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">EMAIL</label>
        <input type="email" name="email" value="<%= member?.email||'' %>" placeholder="member@gcettb.ac.in" class="input-dark text-sm" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">BATCH / JOINED YEAR</label>
        <input type="text" name="batch" value="<%= member?.batch||'' %>" placeholder="2022-2026" class="input-dark text-sm" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">ACHIEVEMENTS (one per line)</label>
        <textarea name="achievements" rows="3" placeholder="Best Project Award 2023&#10;Hackathon Winner" class="input-dark text-sm resize-none"><%= member?.achievements?.join('\n')||'' %></textarea>
      </div>
      <% if (member?._id) { %>
      <div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="isActive" value="true" <%= member?.isActive?'checked':'' %> class="accent-neon" />
          <span class="text-gray-400 text-sm">Active (show on public page)</span>
        </label>
      </div>
      <% } %>
      <div class="flex gap-3">
        <button type="submit" class="btn-neon-solid px-8 py-3 font-display tracking-widest text-sm"><%= member?._id ? 'UPDATE' : 'ADD' %> MEMBER</button>
        <a href="/members/admin" class="btn-neon px-8 py-3 font-display tracking-widest text-sm">CANCEL</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
