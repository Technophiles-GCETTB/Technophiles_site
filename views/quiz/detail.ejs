<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-3xl mx-auto">
  <div class="mb-6"><a href="/quiz" class="text-gray-500 text-sm hover:text-neon font-mono">← BACK</a></div>
  <div class="card p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
    <div class="flex items-start justify-between mb-4">
      <span class="badge badge-neon"><%= quiz.accessLevel==='all'?'PUBLIC':'INTERNAL' %></span>
      <span class="text-neon font-mono">+<%= quiz.pointsReward %> pts</span>
    </div>
    <h1 class="font-display font-bold text-white text-3xl mb-3"><%= quiz.title %></h1>
    <% if (quiz.description) { %><p class="text-gray-400 mb-6"><%= quiz.description %></p><% } %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="card p-3 text-center"><p class="text-xl font-display font-black text-white"><%= quiz.questions.length %></p><p class="text-xs text-gray-500 font-mono">QUESTIONS</p></div>
      <div class="card p-3 text-center"><p class="text-xl font-display font-black text-white"><%= quiz.duration %></p><p class="text-xs text-gray-500 font-mono">MINUTES</p></div>
      <div class="card p-3 text-center"><p class="text-xl font-display font-black text-white"><%= quiz.totalMarks %></p><p class="text-xs text-gray-500 font-mono">MARKS</p></div>
      <div class="card p-3 text-center"><p class="text-xl font-display font-black text-white"><%= quiz.passingMarks %></p><p class="text-xs text-gray-500 font-mono">PASSING</p></div>
    </div>
    <div class="p-4 bg-neon/5 border border-neon/20 rounded mb-6 text-sm text-gray-400 space-y-1">
      <p>• You have <strong class="text-white"><%= quiz.maxAttempts %></strong> attempt(s) — used: <strong class="text-white"><%= attemptCount %></strong></p>
      <p>• Questions are shuffled each attempt</p>
      <p>• Timer starts when you click Begin</p>
      <p>• Passing score: <%= quiz.passingMarks %>/<%= quiz.totalMarks %> (<%= Math.round((quiz.passingMarks/quiz.totalMarks)*100) %>%)</p>
    </div>
    <% if (canAttempt) { %>
    <a href="/quiz/<%= quiz._id %>/start" class="btn-neon-solid px-10 py-3 font-display tracking-widest text-sm inline-block">BEGIN QUIZ →</a>
    <% } else { %>
    <div class="text-center">
      <p class="text-gray-500 mb-3">You've used all attempts</p>
      <a href="/quiz/<%= quiz._id %>/scoreboard" class="btn-neon text-sm">VIEW SCOREBOARD</a>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
