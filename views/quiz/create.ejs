<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-3xl mx-auto">
  <div class="mb-6"><a href="/quiz" class="text-gray-500 text-sm hover:text-neon font-mono">← BACK</a></div>
  <div class="card p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
    <h1 class="font-display font-bold text-white text-2xl tracking-widest mb-8">CREATE QUIZ</h1>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded text-sm mb-6">⚠ <%= error %></div>
    <% } %>
    <form action="/quiz" method="POST" id="quiz-form" class="space-y-5">
      <div><label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">TITLE *</label><input type="text" name="title" required placeholder="JavaScript Fundamentals Quiz" class="input-dark" /></div>
      <div><label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DESCRIPTION</label><textarea name="description" rows="2" placeholder="Quiz description..." class="input-dark resize-none text-sm"></textarea></div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div><label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DURATION (min)</label><input type="number" name="duration" value="30" min="1" class="input-dark" /></div>
        <div><label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">MAX ATTEMPTS</label><input type="number" name="maxAttempts" value="1" min="1" class="input-dark" /></div>
        <div><label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">POINTS REWARD</label><input type="number" name="pointsReward" value="20" class="input-dark" /></div>
      </div>
      <div><label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">ACCESS</label><select name="accessLevel" class="input-dark"><option value="internal_only">Internal Only</option><option value="all">All Users</option></select></div>

      <!-- Questions -->
      <div class="pt-4 border-t border-dark-border">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-display text-white font-bold text-sm tracking-widest">QUESTIONS</h2>
          <button type="button" onclick="addQuestion()" class="btn-neon text-xs px-4">+ ADD QUESTION</button>
        </div>
        <div id="questions-container" class="space-y-6"></div>
        <input type="hidden" name="questionCount" id="questionCount" value="0" />
      </div>

      <button type="submit" class="btn-neon-solid px-8 py-3 font-display tracking-widest text-sm">CREATE QUIZ</button>
    </form>
  </div>
</main>

<script>
let qCount = 0;
function addQuestion() {
  const i = qCount++;
  document.getElementById('questionCount').value = qCount;
  const div = document.createElement('div');
  div.className = 'card p-5 relative';
  div.innerHTML = `
    <button type="button" onclick="this.parentElement.remove()" class="absolute top-3 right-3 text-gray-500 hover:text-red-400 text-xs font-mono">REMOVE</button>
    <p class="text-neon font-mono text-xs mb-3 tracking-widest">QUESTION ${i+1}</p>
    <div class="space-y-3">
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-mono">QUESTION TEXT *</label>
        <textarea name="questions[${i}][question]" required rows="2" placeholder="Enter question..." class="input-dark text-sm resize-none"></textarea>
        <input type="hidden" name="questions[][question]" value="placeholder_${i}" style="display:none">
      </div>
      <div class="grid grid-cols-2 gap-2">
        ${['A','B','C','D'].map((letter, oIdx) => `
          <div>
            <label class="block text-xs text-gray-400 mb-1 font-mono">OPTION ${letter}</label>
            <input type="text" name="questions[${i}][options][${oIdx}]" placeholder="Option ${letter}" class="input-dark text-sm" />
          </div>
        `).join('')}
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-1 font-mono">CORRECT OPTION (0-3)</label>
          <select name="questions[${i}][correct]" class="input-dark text-sm">
            ${['A (0)','B (1)','C (2)','D (3)'].map((l,v)=>`<option value="${v}">${l}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1 font-mono">MARKS</label>
          <input type="number" name="questions[${i}][marks]" value="1" min="1" class="input-dark text-sm" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1 font-mono">EXPLANATION (optional)</label>
        <input type="text" name="questions[${i}][explanation]" placeholder="Why is this answer correct?" class="input-dark text-sm" />
      </div>
    </div>
  `;
  document.getElementById('questions-container').appendChild(div);
}
// Start with one question
addQuestion();
</script>
<%- include('../partials/footer') %>
