<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-16">
  <!-- Hero -->
  <section class="relative py-28 px-4 overflow-hidden">
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(57,255,20,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(57,255,20,0.03) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full" style="background: radial-gradient(circle, rgba(57,255,20,0.06) 0%, transparent 70%);"></div>
    <div class="max-w-4xl mx-auto text-center relative">
      <p class="text-neon font-mono text-xs tracking-widest mb-4">◈ WHO WE ARE</p>
      <h1 class="font-display font-black text-white mb-6" style="font-size: clamp(2rem, 6vw, 4.5rem);">
        TECHNO<span class="neon-text">PHILES</span>
      </h1>
      <p class="text-gray-400 text-xl leading-relaxed max-w-2xl mx-auto"><%= page.mission || 'Building the future, one line of code at a time. The official tech club of GCETTB.' %></p>
      <% if (page.founded) { %>
      <div class="mt-8 inline-flex items-center gap-3 px-5 py-2 border border-neon/30 rounded bg-neon/5">
        <span class="text-gray-500 text-sm">Founded</span>
        <span class="text-neon font-display font-bold text-xl"><%= page.founded %></span>
        <span class="text-gray-500 text-sm">·</span>
        <span class="text-gray-400 text-sm"><%= page.collegeAffiliation || 'GCETTB' %></span>
      </div>
      <% } %>
    </div>
  </section>

  <!-- Stats -->
  <% if (page.stats && page.stats.length > 0) { %>
  <section class="py-16 px-4 bg-dark-card">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-6">
      <% page.stats.forEach(stat => { %>
      <div class="card p-6 text-center">
        <% if (stat.icon) { %><p class="text-3xl mb-2"><%= stat.icon %></p><% } %>
        <p class="text-3xl font-display font-black neon-text"><%= stat.value %></p>
        <p class="text-gray-500 text-xs font-mono mt-1 tracking-widest"><%= stat.label.toUpperCase() %></p>
      </div>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- Mission & Vision -->
  <section class="py-20 px-4 max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="card p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full bg-neon"></div>
        <div class="pl-4">
          <p class="text-neon font-mono text-xs tracking-widest mb-3">OUR MISSION</p>
          <p class="text-gray-300 leading-relaxed text-lg"><%= page.mission || 'Fostering a culture of innovation, learning, and collaboration among students.' %></p>
        </div>
      </div>
      <div class="card p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full" style="background: #7c3aed"></div>
        <div class="pl-4">
          <p class="font-mono text-xs tracking-widest mb-3" style="color:#a78bfa">OUR VISION</p>
          <p class="text-gray-300 leading-relaxed text-lg"><%= page.vision || 'To be the premier tech community that shapes the next generation of engineers.' %></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Rich Content -->
  <% if (page.content) { %>
  <section class="py-10 px-4 max-w-4xl mx-auto">
    <div class="card p-8 text-gray-300 leading-relaxed"><%- page.content %></div>
  </section>
  <% } %>

  <!-- Core Team Preview -->
  <% if (coreMembers.length > 0) { %>
  <section class="py-20 px-4 max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-neon font-mono text-xs tracking-widest mb-2">◈ THE CORE TEAM</p>
      <h2 class="font-display font-bold text-white text-3xl">MEET THE TEAM</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5 mb-8">
      <% coreMembers.forEach(m => { %>
      <div class="card p-4 text-center group hover:border-neon/30 transition-all">
        <img src="<%= m.image %>" alt="<%= m.name %>" class="w-16 h-16 rounded-full object-cover mx-auto mb-3 border-2 border-dark-border group-hover:border-neon/40 transition-all" onerror="this.src='/images/default-avatar.png'">
        <p class="text-white font-semibold text-sm"><%= m.name %></p>
        <p class="text-neon text-xs font-mono mt-0.5"><%= m.post %></p>
      </div>
      <% }) %>
    </div>
    <div class="text-center"><a href="/members" class="btn-neon text-sm px-8 py-2">VIEW ALL MEMBERS →</a></div>
  </section>
  <% } %>

  <!-- Social Links -->
  <% if (page.socialLinks && Object.values(page.socialLinks).some(Boolean)) { %>
  <section class="py-12 px-4 bg-dark-card">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-gray-500 font-mono text-xs tracking-widest mb-6">CONNECT WITH US</p>
      <div class="flex flex-wrap justify-center gap-3">
        <% const socials = [['github','GitHub','GH'],['linkedin','LinkedIn','in'],['instagram','Instagram','ig'],['twitter','Twitter','tw'],['youtube','YouTube','YT'],['discord','Discord','💬'],['website','Website','🌐']]; %>
        <% socials.forEach(([key, label, icon]) => { %>
        <% if (page.socialLinks[key]) { %>
        <a href="<%= page.socialLinks[key] %>" target="_blank" class="flex items-center gap-2 px-4 py-2 border border-dark-border rounded hover:border-neon hover:text-neon text-gray-400 transition-all text-sm font-mono">
          <span><%= icon %></span><span><%= label %></span>
        </a>
        <% } %>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>
</main>

<% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
<div class="fixed bottom-6 right-6"><a href="/about/edit" class="btn-neon-solid text-sm px-5 py-3">✏️ EDIT PAGE</a></div>
<% } %>
<%- include('../partials/footer') %>
