<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 pb-16 px-4 max-w-4xl mx-auto">
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
    <!-- Left: Profile Card -->
    <div class="md:col-span-1">
      <div class="card p-6 text-center">
        <img src="<%= user.avatar %>" alt="<%= user.name %>" class="w-24 h-24 rounded-full border-2 border-neon/40 mx-auto mb-4 object-cover" onerror="this.src='/images/default-avatar.png'">
        <h2 class="text-white font-bold text-lg"><%= user.name %></h2>
        <p class="text-gray-500 text-sm mb-3"><%= user.email %></p>
        <span class="badge badge-neon"><%= user.role %></span>
        <div class="mt-4 p-3 bg-dark-hover rounded border border-dark-border">
          <div class="neon-text font-display font-bold text-2xl"><%= user.points || 0 %></div>
          <div class="text-gray-500 text-xs tracking-widest">TOTAL POINTS</div>
        </div>
        <% if (user.badges && user.badges.length > 0) { %>
          <div class="mt-3 flex flex-wrap gap-1 justify-center">
            <% user.badges.forEach(b => { %><span class="badge badge-yellow text-xs"><%= b %></span><% }) %>
          </div>
        <% } %>
        <div class="mt-4 space-y-2 text-sm text-gray-400 text-left">
          <% if (user.college) { %><div class="flex items-center gap-2"><span class="text-gray-600">🏫</span><%= user.college %></div><% } %>
          <% if (user.branch) { %><div class="flex items-center gap-2"><span class="text-gray-600">📚</span><%= user.branch %><% if (user.year) { %> · Year <%= user.year %><% } %></div><% } %>
          <% if (user.github) { %><a href="https://github.com/<%= user.github %>" target="_blank" class="flex items-center gap-2 hover:text-neon"><span>⌨️</span>github.com/<%= user.github %></a><% } %>
          <% if (user.linkedin) { %><a href="<%= user.linkedin %>" target="_blank" class="flex items-center gap-2 hover:text-neon"><span>💼</span>LinkedIn Profile</a><% } %>
        </div>
      </div>
    </div>

    <!-- Right: Edit Form -->
    <div class="md:col-span-2">
      <div class="card p-6">
        <h3 class="font-display text-sm tracking-widest text-neon mb-6">EDIT PROFILE</h3>
        <form action="/auth/profile" method="POST" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2 md:col-span-1">
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">FULL NAME</label>
              <input type="text" name="name" value="<%= user.name %>" class="input-dark" />
            </div>
            <div class="col-span-2 md:col-span-1">
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">PHONE</label>
              <input type="text" name="phone" value="<%= user.phone || '' %>" class="input-dark" placeholder="+91 XXXXX XXXXX" />
            </div>
            <div class="col-span-2">
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">BIO</label>
              <textarea name="bio" rows="3" class="input-dark resize-none" placeholder="Tell us about yourself..."><%= user.bio || '' %></textarea>
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">COLLEGE</label>
              <input type="text" name="college" value="<%= user.college || '' %>" class="input-dark" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">BRANCH</label>
              <input type="text" name="branch" value="<%= user.branch || '' %>" class="input-dark" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">YEAR</label>
              <select name="year" class="input-dark">
                <option value="">Select</option>
                <% [1,2,3,4].forEach(y => { %>
                  <option value="<%= y %>" <%= user.year == y ? 'selected' : '' %>>Year <%= y %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">GITHUB USERNAME</label>
              <input type="text" name="github" value="<%= user.github || '' %>" class="input-dark" placeholder="username" />
            </div>
            <div class="col-span-2">
              <label class="block text-xs text-gray-400 mb-2 tracking-widest font-mono">LINKEDIN URL</label>
              <input type="text" name="linkedin" value="<%= user.linkedin || '' %>" class="input-dark" placeholder="https://linkedin.com/in/..." />
            </div>
          </div>
          <button type="submit" class="btn-neon-solid px-8 py-2 text-sm">SAVE CHANGES</button>
        </form>
      </div>

      <!-- Enrolled Courses -->
      <% if (user.enrolledCourses && user.enrolledCourses.length > 0) { %>
      <div class="card p-6 mt-4">
        <h3 class="font-display text-sm tracking-widest text-neon mb-4">ENROLLED COURSES</h3>
        <div class="grid grid-cols-2 gap-3">
          <% user.enrolledCourses.forEach(c => { %>
          <a href="/courses/<%= c._id %>" class="flex items-center gap-3 p-3 bg-dark-hover rounded hover:border-neon/30 border border-transparent transition-all">
            <img src="<%= c.thumbnail %>" alt="" class="w-10 h-10 rounded object-cover" onerror="this.src='/images/course-default.jpg'">
            <span class="text-sm text-gray-300 font-semibold"><%= c.title %></span>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Push Notification Settings -->
      <div class="card p-5 mt-4">
        <h3 class="font-display text-neon text-xs font-bold tracking-widest mb-3">🔔 NOTIFICATIONS</h3>
        <p class="text-gray-500 text-xs mb-4 leading-relaxed">Get real-time push notifications for events, live classes, hackathon updates and more — even when the app is closed.</p>
        <button id="push-toggle-btn" class="btn-neon text-xs px-4 py-2 w-full font-mono">
          🔕 Enable Push Notifications
        </button>
        <div id="push-devices" class="mt-3 space-y-2 hidden">
          <p class="text-xs text-gray-500 font-mono tracking-wider">ACTIVE DEVICES</p>
          <div id="push-devices-list" class="space-y-1"></div>
        </div>
        <% if (['superadmin','admin'].includes(user.role)) { %>
        <div class="mt-3 pt-3 border-t border-dark-border space-y-2">
          <p class="text-xs text-neon font-mono tracking-wider">ADMIN TOOLS</p>
          <button onclick="sendTestPush()" class="btn-neon text-xs px-4 py-1.5 w-full">🧪 Send Test Push to My Device</button>
          <a href="/certificates/templates" class="sidebar-link text-xs">📜 Certificate Templates</a>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<script>
// Load push subscription state and devices
async function loadPushState() {
  try {
    const res = await fetch('/push/subscriptions');
    const data = await res.json();
    if (data.success && data.subscriptions.length > 0) {
      updatePushButtonState(true);
      const list = document.getElementById('push-devices-list');
      list.innerHTML = data.subscriptions.map(s => `
        <div class="flex items-center justify-between p-2 bg-dark-hover rounded text-xs">
          <span class="text-gray-300">📱 ${s.deviceName || 'Device'}</span>
          <span class="text-gray-600 font-mono">${new Date(s.lastUsed).toLocaleDateString()}</span>
        </div>
      `).join('');
      document.getElementById('push-devices').classList.remove('hidden');
    } else {
      updatePushButtonState(false);
    }
  } catch(e) {}
}

function updatePushButtonState(isOn) {
  const btn = document.getElementById('push-toggle-btn');
  if (!btn) return;
  if (isOn) {
    btn.textContent = '🔔 Notifications ON — Click to Disable';
    btn.className = btn.className.replace('btn-neon', '') + ' btn-neon text-xs px-4 py-2 w-full font-mono';
    btn.style.color = '#39FF14';
    btn.onclick = () => window.unsubscribeFromPush?.();
  } else {
    btn.textContent = '🔕 Enable Push Notifications';
    btn.style.color = '';
    btn.onclick = () => window.subscribeToPush?.();
  }
}

async function sendTestPush() {
  const btn = event.target;
  btn.textContent = 'Sending...';
  btn.disabled = true;
  try {
    const r = await fetch('/push/send-test', { method: 'POST' });
    const d = await r.json();
    btn.textContent = d.success ? `✅ ${d.message}` : '❌ Failed';
  } catch(e) {
    btn.textContent = '❌ Error';
  }
  setTimeout(() => { btn.textContent = '🧪 Send Test Push to My Device'; btn.disabled = false; }, 3000);
}

document.addEventListener('DOMContentLoaded', loadPushState);
</script>
<%- include('../partials/footer') %>
