<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-16 min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="card p-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
      <div class="text-center mb-8">
        <div class="text-4xl mb-3">🔐</div>
        <h1 class="font-display font-bold text-white text-2xl tracking-widest">FORGOT PASSWORD</h1>
        <p class="text-gray-500 text-sm mt-1">We'll send a reset link to your email</p>
      </div>
      <% if (error) { %>
      <div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded text-sm mb-6">⚠ <%= error %></div>
      <% } %>
      <% if (success) { %>
      <div class="bg-neon/10 border border-neon/30 text-neon px-4 py-3 rounded text-sm mb-6">✅ <%= success %></div>
      <% } %>
      <form action="/auth/forgot-password" method="POST" class="space-y-5">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">EMAIL ADDRESS</label>
          <input type="email" name="email" required placeholder="you@gcettb.ac.in" class="input-dark text-sm" />
        </div>
        <button type="submit" class="btn-neon-solid w-full py-3 font-display tracking-widest text-sm">SEND RESET LINK</button>
      </form>
      <div class="mt-6 pt-6 border-t border-dark-border text-center">
        <a href="/auth/login" class="text-neon text-sm hover:underline font-mono">← BACK TO LOGIN</a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
