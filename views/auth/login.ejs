<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-16 min-h-screen flex items-center justify-center px-3 sm:px-4 py-8">
  <div class="w-full max-w-md">
    <div class="card p-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
      <div class="text-center mb-8">
        <div class="w-12 h-12 border border-neon neon-glow flex items-center justify-center mx-auto mb-4">
          <span class="text-neon font-display font-black">T</span>
        </div>
        <h1 class="font-display font-bold text-white text-2xl tracking-widest">WELCOME BACK</h1>
        <p class="text-gray-500 text-sm mt-1">Sign in to your account</p>
      </div>
      <% if (error) { %>
      <div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded text-sm mb-6">⚠ <%= error %></div>
      <% } %>
      <form action="/auth/login" method="POST" class="space-y-5">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">EMAIL ADDRESS</label>
          <input type="email" name="email" required placeholder="you@example.com" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">PASSWORD</label>
          <div class="relative">
            <input type="password" name="password" id="password" required placeholder="••••••••" class="input-dark text-sm pr-16" />
            <button type="button" onclick="this.previousElementSibling.type=this.previousElementSibling.type==='password'?'text':'password'" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-neon text-xs font-mono">SHOW</button>
          </div>
          <div class="text-right mt-1">
            <a href="/auth/forgot-password" class="text-xs text-gray-500 hover:text-neon font-mono transition-colors">Forgot password?</a>
          </div>
        </div>
        <button type="submit" class="btn-neon-solid w-full py-3 font-display tracking-widest text-sm">SIGN IN</button>
      </form>
      <div class="mt-6 pt-6 border-t border-dark-border text-center">
        <p class="text-gray-500 text-sm">Don't have an account? <a href="/auth/register" class="text-neon hover:underline font-semibold">Register</a></p>
      </div>
      <div class="mt-4 p-3 bg-neon/5 border border-neon/20 rounded text-xs text-gray-500 font-mono">
        <span class="text-neon">ℹ</span> Use <span class="text-neon">@gcettb.ac.in</span> email for full internal access
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
