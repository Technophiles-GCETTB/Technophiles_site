<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-16 min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="card p-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
      <div class="text-center mb-8">
        <div class="text-4xl mb-3">🔑</div>
        <h1 class="font-display font-bold text-white text-2xl tracking-widest">NEW PASSWORD</h1>
        <p class="text-gray-500 text-sm mt-1">Choose a strong password</p>
      </div>
      <% if (error) { %>
      <div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded text-sm mb-6">⚠ <%= error %></div>
      <% } %>
      <% if (token) { %>
      <form action="/auth/reset-password/<%= token %>" method="POST" class="space-y-5">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">NEW PASSWORD</label>
          <input type="password" name="password" required minlength="6" placeholder="Min 6 characters" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">CONFIRM PASSWORD</label>
          <input type="password" name="confirmPassword" required placeholder="Repeat password" class="input-dark text-sm" />
        </div>
        <button type="submit" class="btn-neon-solid w-full py-3 font-display tracking-widest text-sm">RESET PASSWORD</button>
      </form>
      <% } else { %>
      <div class="text-center py-4">
        <p class="text-gray-400 mb-4">This reset link is invalid or has expired.</p>
        <a href="/auth/forgot-password" class="btn-neon text-sm px-6 py-2">REQUEST NEW LINK</a>
      </div>
      <% } %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
