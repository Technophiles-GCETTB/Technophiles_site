<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ ADMIN</p>
      <h1 class="font-display font-bold text-white text-2xl">SYSTEM OVERVIEW</h1>
    </div>
    <div class="flex gap-2">
      <a href="/admin/users" class="btn-neon text-sm">USERS</a>
      <a href="/admin/activity" class="btn-neon text-sm">LOGS</a>
      <button onclick="document.getElementById('notify-modal').classList.remove('hidden')" class="btn-neon-solid text-sm">📢 NOTIFY</button>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <div class="card p-5 text-center border-l-2 border-neon">
      <p class="text-3xl font-display font-black neon-text"><%= stats.totalUsers %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">TOTAL USERS</p>
    </div>
    <div class="card p-5 text-center border-l-2 border-blue-500">
      <p class="text-3xl font-display font-black text-blue-400"><%= stats.totalEvents %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">EVENTS</p>
    </div>
    <div class="card p-5 text-center border-l-2 border-purple-500">
      <p class="text-3xl font-display font-black text-purple-400"><%= stats.totalHackathons %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">HACKATHONS</p>
    </div>
    <div class="card p-5 text-center border-l-2 border-yellow-500">
      <p class="text-3xl font-display font-black text-yellow-400"><%= stats.totalCourses %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">COURSES</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Role Distribution -->
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-widest mb-5">USERS BY ROLE</h2>
      <div class="space-y-3">
        <% roleStats.forEach(r => { %>
        <div class="flex items-center gap-3">
          <span class="text-gray-400 text-sm w-28 font-mono text-xs"><%= r._id.toUpperCase() %></span>
          <div class="flex-1 progress-bar">
            <div class="progress-fill" style="width:<%= stats.totalUsers > 0 ? Math.min((r.count/stats.totalUsers)*100,100) : 0 %>%"></div>
          </div>
          <span class="text-neon font-mono text-sm w-8 text-right"><%= r.count %></span>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Top Users -->
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-widest mb-5">TOP PERFORMERS</h2>
      <div class="space-y-3">
        <% topUsers.forEach((u, i) => { %>
        <div class="flex items-center gap-3">
          <span class="w-6 text-center font-mono text-sm <%= i===0?'text-yellow-400':i===1?'text-gray-300':i===2?'text-orange-500':'text-gray-500' %>">
            <%= i===0?'🥇':i===1?'🥈':i===2?'🥉':'#'+(i+1) %>
          </span>
          <img src="<%= u.avatar||'/images/default-avatar.png' %>" class="w-8 h-8 rounded-full border border-dark-border" onerror="this.src='/images/default-avatar.png'">
          <div class="flex-1 min-w-0">
            <p class="text-white text-sm font-semibold truncate"><%= u.name %></p>
            <p class="text-xs text-gray-500 font-mono"><%= u.role %></p>
          </div>
          <span class="text-neon font-mono font-bold"><%= u.points %></span>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Push Notifications Broadcast -->
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-widest mb-5">📢 PUSH BROADCAST</h2>
      <p class="text-gray-500 text-xs mb-4">Send real-time browser push notifications to all users or specific groups.</p>
      <form id="push-broadcast-form" class="space-y-3" onsubmit="sendBroadcast(event)">
        <div>
          <label class="block text-xs text-gray-400 mb-1 font-mono">TITLE</label>
          <input type="text" id="pb-title" required placeholder="Event Reminder 📅" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1 font-mono">MESSAGE</label>
          <textarea id="pb-body" required rows="2" placeholder="Your message here..." class="input-dark text-sm resize-none"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-gray-400 mb-1 font-mono">LINK (optional)</label>
            <input type="text" id="pb-url" placeholder="/events or /dashboard" class="input-dark text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1 font-mono">TARGET</label>
            <select id="pb-target" class="input-dark text-sm">
              <option value="all">All Users</option>
              <option value="internal">Internal Students Only</option>
            </select>
          </div>
        </div>
        <button type="submit" id="pb-btn" class="btn-neon-solid w-full py-2 text-sm font-display tracking-widest">SEND PUSH NOTIFICATION</button>
        <div id="pb-result" class="hidden text-center text-sm font-mono py-2"></div>
      </form>
      <div class="mt-4 pt-4 border-t border-dark-border">
        <p class="text-xs text-gray-600">💡 Push requires VAPID keys in .env. <a href="/certificates/templates" class="text-neon hover:underline">Manage cert templates →</a></p>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">QUICK ACTIONS</h2>
      <div class="grid grid-cols-2 gap-3">
        <% [
          ['/events/create','📅','Create Event'],
          ['/hackathons/create','⚡','Create Hackathon'],
          ['/courses/create','📚','Create Course'],
          ['/quiz/create','🧠','Create Quiz'],
          ['/sponsors/create','🤝','Add Sponsor'],
          ['/admin/activity','📋','Activity Logs'],
          ['/admin/settings/seo','🔍','SEO & Branding'],
          ['/certificates/templates','📜','Cert Templates'],
        ].forEach(([href, icon, label]) => { %>
        <a href="<%= href %>" class="card p-4 flex items-center gap-3 hover:border-neon/40 transition-all">
          <span class="text-xl"><%= icon %></span>
          <span class="text-sm text-gray-300"><%= label %></span>
        </a>
        <% }) %>
      </div>
    </div>

    <!-- Platform Links -->
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">PLATFORM AREAS</h2>
      <div class="space-y-2">
        <% [
          ['/events','Events Management'],
          ['/hackathons','Hackathon Management'],
          ['/courses','Course Management'],
          ['/quiz','Quiz Management'],
          ['/leaderboard','Leaderboard'],
          ['/sponsors','Sponsors'],
        ].forEach(([href, label]) => { %>
        <a href="<%= href %>" class="sidebar-link text-sm"><span class="text-neon">→</span><%= label %></a>
        <% }) %>
      </div>
    </div>
  </div>
</main>

<!-- Notify Modal -->
<div id="notify-modal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">  <div class="card p-8 max-w-lg w-full">
    <h3 class="font-display text-neon font-bold tracking-widest mb-6">SEND NOTIFICATION</h3>
    <form action="/admin/notify" method="POST" class="space-y-4">
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono">TITLE</label>
        <input type="text" name="title" required placeholder="Notification title" class="input-dark text-sm" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono">MESSAGE</label>
        <textarea name="message" required rows="3" placeholder="Message content..." class="input-dark text-sm resize-none"></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">TARGET</label>
          <select name="target" class="input-dark text-sm">
            <option value="all">All Users</option>
            <option value="internal">Internal Only</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">TYPE</label>
          <select name="type" class="input-dark text-sm">
            <option value="announcement">Announcement</option>
            <option value="system">System</option>
            <option value="event_reminder">Event Reminder</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono">LINK (optional)</label>
        <input type="text" name="link" placeholder="/events/..." class="input-dark text-sm" />
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('notify-modal').classList.add('hidden')" class="btn-neon flex-1 py-2 text-sm">CANCEL</button>
        <button type="submit" class="btn-neon-solid flex-1 py-2 text-sm font-display tracking-widest">SEND</button>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
<script>
async function sendBroadcast(e) {
  e.preventDefault();
  const btn = document.getElementById('pb-btn');
  const result = document.getElementById('pb-result');
  btn.disabled = true;
  btn.textContent = 'SENDING...';
  result.className = 'text-center text-sm font-mono py-2 text-neon';
  result.textContent = '⏳ Sending...';
  result.classList.remove('hidden');
  try {
    const res = await fetch('/push/broadcast', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        title: document.getElementById('pb-title').value,
        body: document.getElementById('pb-body').value,
        url: document.getElementById('pb-url').value || '/',
        target: document.getElementById('pb-target').value,
      })
    });
    const d = await res.json();
    result.textContent = d.success ? `✅ ${d.message || 'Broadcast sent!'}` : `❌ ${d.message || 'Failed'}`;
    result.className = `text-center text-sm font-mono py-2 ${d.success ? 'text-neon' : 'text-red-400'}`;
    if (d.success) document.getElementById('push-broadcast-form').reset();
  } catch(err) {
    result.textContent = '❌ Network error';
    result.className = 'text-center text-sm font-mono py-2 text-red-400';
  }
  btn.disabled = false;
  btn.textContent = 'SEND PUSH NOTIFICATION';
}
</script>
