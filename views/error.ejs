<%- include('partials/head') %>
<%- include('partials/navbar') %>
<main class="pt-16 min-h-screen flex items-center justify-center px-4">
  <div class="text-center max-w-md">
    <p class="font-display font-black text-red-500" style="font-size:5rem;line-height:1;">ERROR</p>
    <h1 class="font-display font-bold text-white text-2xl mt-4 mb-2"><%= title || 'Something Went Wrong' %></h1>
    <p class="text-gray-500 mb-4"><%= message || 'An unexpected error occurred.' %></p>
    <% if (typeof error !== 'undefined' && error && error.stack) { %>
    <pre class="text-left card p-4 text-xs text-red-400 font-mono overflow-auto mb-6 max-h-48"><%= error.stack %></pre>
    <% } %>
    <div class="flex gap-3 justify-center">
      <a href="javascript:history.back()" class="btn-neon px-6 py-2 text-sm">← BACK</a>
      <a href="/" class="btn-neon-solid px-6 py-2 text-sm">HOME</a>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
