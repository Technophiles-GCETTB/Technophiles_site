<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-2xl mx-auto">
  <div class="mb-6"><a href="/sponsors" class="text-gray-500 text-sm hover:text-neon font-mono">← BACK</a></div>
  <div class="card p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
    <h1 class="font-display font-bold text-white text-2xl tracking-widest mb-8">ADD SPONSOR</h1>
    <form action="/sponsors" method="POST" class="space-y-5">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">COMPANY NAME *</label>
          <input type="text" name="name" required placeholder="Acme Corp" class="input-dark" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">TIER</label>
          <select name="tier" class="input-dark">
            <% ['title','platinum','gold','silver','bronze','community'].forEach(t => { %>
            <option value="<%= t %>"><%= t.toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">WEBSITE</label>
        <input type="url" name="website" placeholder="https://acme.com" class="input-dark" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">LOGO URL</label>
        <input type="url" name="logo" placeholder="https://acme.com/logo.png" class="input-dark" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DESCRIPTION</label>
        <textarea name="description" rows="3" placeholder="About the sponsor..." class="input-dark resize-none text-sm"></textarea>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">CONTACT NAME</label>
          <input type="text" name="contactName" placeholder="John Doe" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">CONTACT EMAIL</label>
          <input type="email" name="contactEmail" placeholder="john@acme.com" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">AMOUNT (₹)</label>
          <input type="number" name="amount" placeholder="50000" class="input-dark text-sm" />
        </div>
      </div>
      <button type="submit" class="btn-neon-solid px-8 py-3 font-display tracking-widest text-sm">ADD SPONSOR</button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
