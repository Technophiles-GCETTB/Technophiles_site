<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-10">
    <div>
      <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ PARTNERS</p>
      <h1 class="font-display font-bold text-white text-3xl">OUR SPONSORS</h1>
    </div>
    <% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
    <a href="/sponsors/create" class="btn-neon-solid text-sm">+ ADD SPONSOR</a>
    <% } %>
  </div>
  <%
    const tierOrder = ['title','platinum','gold','silver','bronze','community'];
    const tierConfig = {
      title: { label: 'TITLE SPONSOR', color: 'border-purple-500/50', badge: 'bg-purple-500/20 text-purple-300 border-purple-500/40' },
      platinum: { label: 'PLATINUM', color: 'border-gray-300/30', badge: 'bg-gray-300/10 text-gray-300 border-gray-300/30' },
      gold: { label: 'GOLD', color: 'border-yellow-500/40', badge: 'bg-yellow-500/15 text-yellow-400 border-yellow-500/30' },
      silver: { label: 'SILVER', color: 'border-gray-400/30', badge: 'bg-gray-400/10 text-gray-400 border-gray-400/20' },
      bronze: { label: 'BRONZE', color: 'border-orange-700/40', badge: 'bg-orange-700/15 text-orange-500 border-orange-700/30' },
      community: { label: 'COMMUNITY', color: 'border-neon/20', badge: 'badge-neon' },
    };
  %>
  <% tierOrder.forEach(tier => { %>
  <% if (grouped[tier] && grouped[tier].length > 0) { %>
  <section class="mb-12">
    <div class="flex items-center gap-4 mb-6">
      <div class="flex-1 h-px bg-dark-border"></div>
      <span class="text-xs font-mono tracking-widest text-gray-500"><%= tierConfig[tier].label %></span>
      <div class="flex-1 h-px bg-dark-border"></div>
    </div>
    <div class="flex flex-wrap justify-center gap-4 sm:gap-6">
      <% grouped[tier].forEach(sponsor => { %>
      <a href="<%= sponsor.website||'#' %>" target="_blank" class="card p-6 flex flex-col items-center text-center hover:border-neon/30 transition-all <%= tierConfig[tier].color %> <%= tier==='title'?'w-64':tier==='platinum'?'w-48':tier==='gold'?'w-40':'w-32' %>">
        <% if (sponsor.logo) { %>
        <img src="<%= sponsor.logo %>" alt="<%= sponsor.name %>" class="h-12 object-contain mb-3 grayscale hover:grayscale-0 transition-all">
        <% } %>
        <p class="text-white font-bold text-sm"><%= sponsor.name %></p>
        <% if (sponsor.description && tier === 'title') { %><p class="text-gray-500 text-xs mt-2 line-clamp-2"><%= sponsor.description %></p><% } %>
        <span class="mt-3 badge <%= tierConfig[tier].badge %> text-xs"><%= tier.toUpperCase() %></span>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>
  <% }) %>
  <% if (sponsors.length === 0) { %>
  <div class="text-center py-20 card"><p class="text-4xl mb-4">🤝</p><p class="text-gray-400">No sponsors yet</p></div>
  <% } %>
</main>
<%- include('../partials/footer') %>
