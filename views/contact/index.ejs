<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-6xl mx-auto">
  <div class="text-center mb-12">
    <p class="text-neon font-mono text-xs tracking-widest mb-2">◈ GET IN TOUCH</p>
    <h1 class="font-display font-black text-white text-4xl">CONTACT US</h1>
  </div>

  <% if (sent === '1') { %>
  <div class="bg-neon/10 border border-neon/30 text-neon px-5 py-4 rounded text-sm mb-8 text-center">✅ Message sent! We'll get back to you soon.</div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 sm:gap-8">
    <!-- Contact Form -->
    <div class="card p-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
      <h2 class="font-display text-white font-bold text-lg tracking-wide mb-6">SEND A MESSAGE</h2>
      <form action="/contact" method="POST" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-400 mb-2 font-mono">YOUR NAME *</label>
            <input type="text" name="name" required placeholder="Rahul Sharma" class="input-dark text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-2 font-mono">EMAIL *</label>
            <input type="email" name="email" required placeholder="you@example.com" class="input-dark text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">SUBJECT *</label>
          <input type="text" name="subject" required placeholder="Collaboration / Query / Feedback..." class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">MESSAGE *</label>
          <textarea name="message" required rows="5" placeholder="Your message here..." class="input-dark text-sm resize-none"></textarea>
        </div>
        <button type="submit" class="btn-neon-solid w-full py-3 font-display tracking-widest text-sm">SEND MESSAGE</button>
      </form>
    </div>

    <!-- Info & FAQs -->
    <div class="space-y-6">
      <div class="card p-6">
        <h2 class="font-display text-white font-bold text-sm tracking-widest mb-5">REACH US</h2>
        <div class="space-y-4">
          <% if (page.contactEmail) { %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-neon/10 border border-neon/20 rounded flex items-center justify-center text-neon">✉</div>
            <div><p class="text-gray-400 text-xs font-mono">EMAIL</p><a href="mailto:<%= page.contactEmail %>" class="text-white hover:text-neon"><%= page.contactEmail %></a></div>
          </div>
          <% } %>
          <% if (page.contactPhone) { %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-neon/10 border border-neon/20 rounded flex items-center justify-center text-neon">📞</div>
            <div><p class="text-gray-400 text-xs font-mono">PHONE</p><p class="text-white"><%= page.contactPhone %></p></div>
          </div>
          <% } %>
          <% if (page.address) { %>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-neon/10 border border-neon/20 rounded flex items-center justify-center text-neon flex-shrink-0">📍</div>
            <div><p class="text-gray-400 text-xs font-mono">ADDRESS</p><p class="text-white text-sm"><%= page.address %></p></div>
          </div>
          <% } %>
          <% if (!page.contactEmail && !page.contactPhone && !page.address) { %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-neon/10 border border-neon/20 rounded flex items-center justify-center text-neon">✉</div>
            <div><p class="text-gray-400 text-xs font-mono">EMAIL</p><a href="mailto:technophiles@gcettb.ac.in" class="text-white hover:text-neon">technophiles@gcettb.ac.in</a></div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-neon/10 border border-neon/20 rounded flex items-center justify-center text-neon flex-shrink-0">📍</div>
            <div><p class="text-gray-400 text-xs font-mono">ADDRESS</p><p class="text-white text-sm">GCETTB, Murshidabad, West Bengal</p></div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- FAQs -->
      <% if (page.faqs && page.faqs.length > 0) { %>
      <div class="card p-6">
        <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">FAQs</h2>
        <div class="space-y-3">
          <% page.faqs.forEach((faq, i) => { %>
          <div class="border border-dark-border rounded overflow-hidden">
            <button onclick="toggleFaq(this)" class="w-full flex items-center justify-between p-4 text-left hover:bg-dark-hover transition-colors">
              <span class="text-white text-sm font-semibold"><%= faq.question %></span>
              <span class="text-neon text-xs font-mono">+</span>
            </button>
            <div class="hidden px-4 pb-4 text-gray-400 text-sm leading-relaxed"><%= faq.answer %></div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</main>

<% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
<div class="fixed bottom-6 right-6 flex gap-2">
  <a href="/contact/messages" class="btn-neon text-sm px-5 py-3">📬 MESSAGES</a>
  <a href="/contact/edit" class="btn-neon-solid text-sm px-5 py-3">✏️ EDIT</a>
</div>
<% } %>

<script>
function toggleFaq(btn) {
  const content = btn.nextElementSibling;
  const icon = btn.querySelector('span:last-child');
  content.classList.toggle('hidden');
  icon.textContent = content.classList.contains('hidden') ? '+' : '−';
}
</script>
<%- include('../partials/footer') %>
