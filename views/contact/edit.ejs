<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-3xl mx-auto">
  <div class="mb-6"><a href="/contact" class="text-gray-500 text-sm hover:text-neon font-mono">← BACK</a></div>
  <div class="card p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
    <h1 class="font-display font-bold text-white text-2xl tracking-widest mb-8">EDIT CONTACT PAGE</h1>
    <form action="/contact/settings" method="POST" class="space-y-5">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">CONTACT EMAIL</label>
          <input type="email" name="contactEmail" value="<%= page?.contactEmail||'' %>" placeholder="technophiles@gcettb.ac.in" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono">PHONE</label>
          <input type="text" name="contactPhone" value="<%= page?.contactPhone||'' %>" placeholder="+91 9999999999" class="input-dark text-sm" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono">ADDRESS</label>
        <textarea name="address" rows="2" placeholder="GCETTB, Murshidabad..." class="input-dark text-sm resize-none"><%= page?.address||'' %></textarea>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono">GOOGLE MAPS EMBED URL</label>
        <input type="url" name="mapEmbedUrl" value="<%= page?.mapEmbedUrl||'' %>" placeholder="https://maps.google.com/maps?..." class="input-dark text-sm" />
      </div>
      <!-- FAQs -->
      <div>
        <label class="block text-xs text-gray-400 mb-3 font-mono">FREQUENTLY ASKED QUESTIONS</label>
        <div id="faq-container" class="space-y-3">
          <% const faqs = page?.faqs?.length ? page.faqs : [{question:'',answer:''}]; %>
          <% faqs.forEach(faq => { %>
          <div class="faq-row space-y-2 card p-3">
            <input type="text" name="faq_q" value="<%= faq.question %>" placeholder="Question..." class="input-dark text-sm" />
            <textarea name="faq_a" rows="2" placeholder="Answer..." class="input-dark text-sm resize-none"><%= faq.answer %></textarea>
          </div>
          <% }) %>
        </div>
        <button type="button" onclick="addFaq()" class="btn-neon text-xs px-4 py-1.5 mt-2">+ ADD FAQ</button>
      </div>
      <button type="submit" class="btn-neon-solid px-8 py-3 font-display tracking-widest text-sm">SAVE CONTACT PAGE</button>
    </form>
  </div>
</main>
<script>
function addFaq() {
  const row = document.createElement('div');
  row.className = 'faq-row space-y-2 card p-3';
  row.innerHTML = '<input type="text" name="faq_q" placeholder="Question..." class="input-dark text-sm"><textarea name="faq_a" rows="2" placeholder="Answer..." class="input-dark text-sm resize-none"></textarea>';
  document.getElementById('faq-container').appendChild(row);
}
</script>
<%- include('../partials/footer') %>
