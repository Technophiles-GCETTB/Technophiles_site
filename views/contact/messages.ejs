<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ ADMIN</p>
      <h1 class="font-display font-bold text-white text-2xl">CONTACT MESSAGES</h1>
    </div>
    <a href="/admin" class="btn-neon text-sm">← DASHBOARD</a>
  </div>
  <% if (messages.length === 0) { %>
  <div class="card p-12 text-center"><p class="text-4xl mb-4">📭</p><p class="text-gray-400">No messages yet</p></div>
  <% } else { %>
  <div class="space-y-4">
    <% messages.forEach(msg => { %>
    <div class="card p-5 <%= msg.isRead ? 'opacity-70' : 'border-neon/20' %>">
      <div class="flex items-start justify-between mb-3">
        <div>
          <p class="text-white font-bold"><%= msg.name %> <span class="text-gray-500 font-normal text-sm">via <%= msg.email %></span></p>
          <p class="text-neon text-sm mt-0.5"><%= msg.subject %></p>
        </div>
        <div class="text-right">
          <p class="text-gray-500 text-xs font-mono"><%= new Date(msg.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></p>
          <% if (!msg.isRead) { %><span class="badge badge-neon text-xs mt-1">NEW</span><% } %>
        </div>
      </div>
      <p class="text-gray-400 text-sm leading-relaxed bg-dark-hover p-3 rounded"><%= msg.message %></p>
      <div class="mt-3 flex gap-3">
        <a href="mailto:<%= msg.email %>?subject=Re: <%= msg.subject %>" class="btn-neon text-xs px-4 py-1.5">REPLY VIA EMAIL</a>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
