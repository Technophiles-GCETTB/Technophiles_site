<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-4xl mx-auto">
  <div class="mb-8">
    <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ VOLUNTEER PANEL</p>
    <h1 class="font-display font-bold text-white text-2xl">ATTENDANCE MANAGEMENT</h1>
  </div>
  <div class="card p-6 mb-6">
    <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">SCAN QR CODE</h2>
    <p class="text-gray-500 text-sm mb-4">Direct participants to scan their event QR code at: <span class="text-neon font-mono">/attendance/scan/[QR_TOKEN]</span></p>
    <p class="text-gray-400 text-sm">Or use the QR code displayed on the event page to let participants self-check in.</p>
  </div>
  <div class="card p-6">
    <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">ACTIVE EVENTS TODAY</h2>
    <% if (events.length === 0) { %>
    <p class="text-gray-500 text-center py-6">No active events right now</p>
    <% } else { %>
    <div class="space-y-3">
      <% events.forEach(event => { %>
      <div class="flex items-center justify-between p-4 rounded bg-dark-hover">
        <div>
          <p class="text-white font-semibold"><%= event.title %></p>
          <p class="text-xs text-gray-500 font-mono"><%= new Date(event.startDate).toLocaleString('en-IN',{hour:'2-digit',minute:'2-digit'}) %> – <%= new Date(event.endDate).toLocaleString('en-IN',{hour:'2-digit',minute:'2-digit'}) %></p>
        </div>
        <div class="flex gap-2">
          <span class="text-xs text-gray-500"><%= event.participants.filter(p=>p.attended).length %>/<%= event.participants.length %> attended</span>
          <a href="/events/<%= event._id %>/participants" class="btn-neon text-xs px-4">MANAGE</a>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
