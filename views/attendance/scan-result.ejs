<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-2xl mx-auto text-center">
  <div class="card p-10 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-<%= success ? 'neon' : 'red-500' %> to-transparent"></div>
    <div class="text-6xl mb-5"><%= success ? '✅' : '❌' %></div>
    <h1 class="font-display font-bold text-white text-3xl mb-3">
      <%= success ? 'ATTENDANCE MARKED!' : 'SCAN FAILED' %>
    </h1>
    <% if (event) { %>
    <p class="text-gray-400 mb-2">Event: <span class="text-white font-semibold"><%= event.title %></span></p>
    <% } %>
    <p class="<%= success ? 'text-neon' : 'text-red-400' %> font-mono text-sm mb-6"><%= message %></p>
    <div class="flex gap-3 justify-center">
      <a href="/dashboard" class="btn-neon px-6 py-2 text-sm">DASHBOARD</a>
      <a href="/attendance/my" class="btn-neon-solid px-6 py-2 text-sm">MY ATTENDANCE</a>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
