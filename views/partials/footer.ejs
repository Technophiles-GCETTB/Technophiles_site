<footer class="border-t border-dark-border mt-16 sm:mt-20 py-10 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <% if (siteSettings && siteSettings.logoNavUrl) { %>
            <img src="<%= siteSettings.logoNavUrl %>" alt="<%= siteSettings.siteName %>" class="h-8 w-auto object-contain">
          <% } else { %>
            <div class="w-8 h-8 border border-neon neon-glow flex items-center justify-center rounded">
              <span class="text-neon font-display text-xs font-black">T</span>
            </div>
            <span class="font-display font-bold text-white text-sm tracking-widest"><%= siteSettings?.siteName || 'TECHNOPHILES' %></span>
          <% } %>
        </div>
        <p class="text-gray-500 text-sm"><%= siteSettings?.tagline || 'Building the future, one line of code at a time.' %></p>
        <!-- Social icons -->
        <% if (siteSettings?.socialLinks) { %>
        <div class="flex gap-2 mt-4 flex-wrap">
          <% if (siteSettings.socialLinks?.github) { %><a href="<%= siteSettings.socialLinks.github %>" target="_blank" class="w-8 h-8 border border-dark-border flex items-center justify-center text-gray-500 hover:border-neon hover:text-neon transition-all rounded text-xs">GH</a><% } %>
          <% if (siteSettings.socialLinks?.linkedin) { %><a href="<%= siteSettings.socialLinks.linkedin %>" target="_blank" class="w-8 h-8 border border-dark-border flex items-center justify-center text-gray-500 hover:border-neon hover:text-neon transition-all rounded text-xs">in</a><% } %>
          <% if (siteSettings.socialLinks?.instagram) { %><a href="<%= siteSettings.socialLinks.instagram %>" target="_blank" class="w-8 h-8 border border-dark-border flex items-center justify-center text-gray-500 hover:border-neon hover:text-neon transition-all rounded text-xs">ig</a><% } %>
          <% if (siteSettings.socialLinks?.twitter) { %><a href="<%= siteSettings.socialLinks.twitter %>" target="_blank" class="w-8 h-8 border border-dark-border flex items-center justify-center text-gray-500 hover:border-neon hover:text-neon transition-all rounded text-xs">tw</a><% } %>
          <% if (siteSettings.socialLinks?.youtube) { %><a href="<%= siteSettings.socialLinks.youtube %>" target="_blank" class="w-8 h-8 border border-dark-border flex items-center justify-center text-gray-500 hover:border-neon hover:text-neon transition-all rounded text-xs">▶</a><% } %>
        </div>
        <% } %>
      </div>
      <div>
        <h4 class="text-neon font-display text-xs tracking-widest mb-4">EXPLORE</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/events" class="hover:text-neon transition-colors">Events</a></li>
          <li><a href="/hackathons" class="hover:text-neon transition-colors">Hackathons</a></li>
          <li><a href="/live-classes" class="hover:text-neon transition-colors">Live Classes</a></li>
          <li><a href="/courses" class="hover:text-neon transition-colors">Courses</a></li>
          <li><a href="/quiz" class="hover:text-neon transition-colors">Quizzes</a></li>
          <li><a href="/roadmaps" class="hover:text-neon transition-colors">Roadmaps</a></li>
          <li><a href="/calendar" class="hover:text-neon transition-colors">Calendar</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-neon font-display text-xs tracking-widest mb-4">COMMUNITY</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="/leaderboard" class="hover:text-neon transition-colors">Leaderboard</a></li>
          <li><a href="/members" class="hover:text-neon transition-colors">Team Members</a></li>
          <li><a href="/projects" class="hover:text-neon transition-colors">Projects</a></li>
          <li><a href="/sponsors" class="hover:text-neon transition-colors">Sponsors</a></li>
          <li><a href="/about" class="hover:text-neon transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-neon transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-neon font-display text-xs tracking-widest mb-4">CONNECT</h4>
        <% if (siteSettings?.collegeWebsite) { %>
        <a href="<%= siteSettings.collegeWebsite %>" target="_blank" class="text-gray-400 text-sm hover:text-neon transition-colors block mb-2">🏫 College Website ↗</a>
        <% } %>
        <a href="/contact" class="text-gray-400 text-sm hover:text-neon transition-colors block mb-2">✉ Contact Us</a>
        <a href="/auth/register" class="btn-neon text-xs px-4 py-2 mt-2 inline-block font-mono">JOIN THE CLUB</a>
      </div>
    </div>
    <div class="border-t border-dark-border mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-center text-xs text-gray-600">
        <%= siteSettings?.footerText || '© ' + new Date().getFullYear() + ' ' + (siteSettings?.siteName || 'Technophiles') + '. Built with ❤️ by the club team.' %>
      </p>
      <div class="flex gap-4 text-xs text-gray-700">
        <a href="/about" class="hover:text-neon transition-colors">About</a>
        <a href="/contact" class="hover:text-neon transition-colors">Contact</a>
        <a href="/auth/login" class="hover:text-neon transition-colors">Login</a>
      </div>
    </div>
  </div>
</footer>

<% if (typeof currentUser !== 'undefined' && currentUser) { %>
<%- include('push-prompt') %>
<% } %>
<script src="/js/main.js"></script>
<script src="/js/pwa.js"></script>
</body>
</html>
