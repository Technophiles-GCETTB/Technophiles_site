<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-3xl mx-auto">
  <div class="mb-6"><a href="/live-classes" class="text-gray-500 text-sm hover:text-neon font-mono">← BACK</a></div>
  <div class="card p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
    <h1 class="font-display font-bold text-white text-2xl tracking-widest mb-8"><%= lc ? 'EDIT LIVE CLASS' : 'SCHEDULE LIVE CLASS' %></h1>
    <% if (typeof error !== 'undefined' && error) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded text-sm mb-6">⚠ <%= error %></div><% } %>
    <form action="<%= lc ? '/live-classes/'+lc._id+'?_method=PUT' : '/live-classes' %>" method="POST" class="space-y-5">      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">TITLE *</label>
        <input type="text" name="title" required value="<%= lc?.title||'' %>" placeholder="Introduction to React Hooks" class="input-dark" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DESCRIPTION</label>
        <textarea name="description" rows="3" placeholder="What will be covered..." class="input-dark resize-none text-sm"><%= lc?.description||'' %></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">SCHEDULED DATE & TIME *</label>
          <input type="datetime-local" name="scheduledAt" required value="<%= lc?.scheduledAt ? new Date(lc.scheduledAt).toISOString().slice(0,16) : '' %>" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">END TIME</label>
          <input type="datetime-local" name="endAt" value="<%= lc?.endAt ? new Date(lc.endAt).toISOString().slice(0,16) : '' %>" class="input-dark text-sm" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">PLATFORM</label>
          <select name="platform" class="input-dark text-sm">
            <% ['google_meet','zoom','teams','other'].forEach(p => { %>
            <option value="<%= p %>" <%= lc?.platform===p?'selected':'' %>><%= p.replace('_',' ').toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DURATION (mins)</label>
          <input type="number" name="duration" value="<%= lc?.duration||60 %>" min="15" class="input-dark text-sm" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">MEETING LINK (Google Meet / Zoom URL)</label>
        <input type="url" name="meetingLink" value="<%= lc?.meetingLink||'' %>" placeholder="https://meet.google.com/abc-defg-hij" class="input-dark text-sm" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">MEETING ID</label>
          <input type="text" name="meetingId" value="<%= lc?.meetingId||'' %>" placeholder="123 456 7890" class="input-dark text-sm" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">MEETING PASSWORD</label>
          <input type="text" name="meetingPassword" value="<%= lc?.meetingPassword||'' %>" placeholder="Optional" class="input-dark text-sm" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">LINKED COURSE</label>
        <select name="course" class="input-dark text-sm">
          <option value="">None (standalone class)</option>
          <% courses.forEach(c => { %>
          <option value="<%= c._id %>" <%= lc?.course?.toString()===c._id.toString()?'selected':'' %>><%= c.title %></option>
          <% }) %>
        </select>
      </div>
      <% if (lc) { %>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">RECORDING LINK (YouTube URL — add after class)</label>
        <input type="url" name="recordingLink" value="<%= lc?.recordingLink||'' %>" placeholder="https://youtube.com/watch?v=..." class="input-dark text-sm" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">CLASS NOTES (HTML)</label>
        <textarea name="notes" rows="5" placeholder="Key concepts, code, links..." class="input-dark text-sm resize-none font-mono"><%= lc?.notes||'' %></textarea>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">STATUS</label>
        <select name="status" class="input-dark text-sm">
          <% ['scheduled','live','completed','cancelled'].forEach(s => { %><option value="<%= s %>" <%= lc?.status===s?'selected':'' %>><%= s.toUpperCase() %></option><% }) %>
        </select>
      </div>
      <% } %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">POINTS REWARD</label>
          <input type="number" name="pointsReward" value="<%= lc?.pointsReward||15 %>" class="input-dark text-sm" />
        </div>
        <div class="flex items-end pb-2">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="isPublic" <%= lc?.isPublic?'checked':'' %> class="accent-neon" />
            <span class="text-gray-400 text-sm">Public (external users can view)</span>
          </label>
        </div>
      </div>
      <button type="submit" class="btn-neon-solid px-8 py-3 font-display tracking-widest text-sm"><%= lc ? 'UPDATE' : 'SCHEDULE' %> CLASS</button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
