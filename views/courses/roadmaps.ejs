<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-6xl mx-auto">
  <div class="mb-6"><a href="/courses" class="text-gray-500 text-sm hover:text-neon font-mono">← COURSES</a></div>
  <div class="text-center mb-12">
    <p class="text-neon font-mono text-xs tracking-widest mb-2">◈ STRUCTURED PATHS</p>
    <h1 class="font-display font-bold text-white text-3xl">LEARNING ROADMAPS</h1>
    <p class="text-gray-500 mt-2">Follow a structured path to master your skills</p>
  </div>
  <% if (roadmaps.length === 0) { %>
  <div class="text-center card p-12"><p class="text-4xl mb-4">🗺</p><p class="text-gray-400">No roadmaps yet. Check back soon!</p></div>
  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 sm:gap-6">
    <% roadmaps.forEach(roadmap => { %>
    <div class="card p-6 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-1 h-full" style="background: <%= roadmap.color || '#39FF14' %>"></div>
      <div class="pl-2">
        <div class="flex items-center gap-3 mb-4">
          <% if (roadmap.icon) { %><span class="text-3xl"><%= roadmap.icon %></span><% } %>
          <div>
            <h3 class="text-white font-bold font-display text-lg"><%= roadmap.title %></h3>
            <% if (roadmap.category) { %><span class="badge badge-gray text-xs"><%= roadmap.category %></span><% } %>
          </div>
        </div>
        <% if (roadmap.description) { %><p class="text-gray-400 text-sm mb-4"><%= roadmap.description %></p><% } %>
        <% if (roadmap.steps?.length) { %>
        <div class="space-y-2">
          <p class="text-xs text-gray-500 font-mono mb-2">STEPS (<%= roadmap.steps.length %>)</p>
          <% roadmap.steps.slice(0,5).forEach((step, i) => { %>
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full border-2 flex-shrink-0 flex items-center justify-center text-xs font-mono" style="border-color: <%= roadmap.color||'#39FF14' %>; color: <%= roadmap.color||'#39FF14' %>"><%= i+1 %></div>
            <div>
              <p class="text-sm text-gray-300"><%= step.title %></p>
              <% if (step.course) { %><a href="/courses/<%= step.course._id %>" class="text-xs text-neon hover:underline"><%= step.course.title %></a><% } %>
            </div>
          </div>
          <% }) %>
          <% if (roadmap.steps.length > 5) { %><p class="text-xs text-gray-600 pl-8">+<%= roadmap.steps.length-5 %> more steps</p><% } %>
        </div>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
