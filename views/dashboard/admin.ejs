<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-7xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6 sm:mb-8">
    <div><p class="text-neon font-mono text-xs tracking-widest mb-1">◈ ADMIN PANEL</p><h1 class="font-display font-bold text-white text-2xl">SYSTEM DASHBOARD</h1></div>
    <div class="flex flex-wrap gap-2">
      <a href="/admin/users" class="btn-neon text-xs">MANAGE USERS</a>
      <a href="/events/create" class="btn-neon-solid text-xs">+ EVENT</a>
    </div>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 mb-8">
    <div class="card p-5 text-center border-l-2 border-neon"><p class="text-3xl font-display font-black neon-text"><%= stats.totalUsers %></p><p class="text-xs text-gray-500 font-mono mt-1">TOTAL USERS</p></div>
    <div class="card p-5 text-center border-l-2 border-blue-500"><p class="text-3xl font-display font-black text-blue-400"><%= stats.totalEvents %></p><p class="text-xs text-gray-500 font-mono mt-1">EVENTS</p></div>
    <div class="card p-5 text-center border-l-2 border-purple-500"><p class="text-3xl font-display font-black text-purple-400"><%= stats.totalHackathons %></p><p class="text-xs text-gray-500 font-mono mt-1">HACKATHONS</p></div>
    <div class="card p-5 text-center border-l-2 border-yellow-500"><p class="text-3xl font-display font-black text-yellow-400"><%= stats.totalCourses %></p><p class="text-xs text-gray-500 font-mono mt-1">COURSES</p></div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-wide mb-4">RECENT USERS</h2>
      <div class="overflow-x-auto -mx-0"><table><thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Joined</th></tr></thead><tbody>
      <% recentUsers.forEach(u => { %>
      <tr>
        <td class="text-white"><%= u.name %></td>
        <td class="text-gray-400 text-xs"><%= u.email %></td>
        <td><span class="badge badge-neon"><%= u.role %></span></td>
        <td class="text-gray-500 text-xs font-mono"><%= new Date(u.createdAt).toLocaleDateString() %></td>
      </tr>
      <% }) %>
      </tbody></table></div>
      <a href="/admin/users" class="block mt-4 text-center text-neon text-xs font-mono hover:underline">VIEW ALL USERS →</a>
    </div>
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-wide mb-4">UPCOMING EVENTS</h2>
      <% if (upcomingEvents.length === 0) { %><p class="text-gray-500 text-center py-4 text-sm">No upcoming events</p>
      <% } else { %><div class="space-y-3"><% upcomingEvents.forEach(event => { %>
      <div class="flex items-center justify-between p-3 rounded bg-dark-hover">
        <div><p class="text-white text-sm font-semibold"><%= event.title %></p><p class="text-xs text-gray-500 font-mono"><%= new Date(event.startDate).toLocaleDateString() %></p></div>
        <span class="badge badge-neon"><%= event.status %></span>
      </div><% }) %></div><% } %>
    </div>
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-wide mb-4">USERS BY ROLE</h2>
      <div class="space-y-3">
        <% roleStats.forEach(r => { %>
        <div class="flex items-center gap-3">
          <span class="text-gray-400 text-sm w-28 font-mono"><%= r._id %></span>
          <div class="flex-1 progress-bar"><div class="progress-fill" style="width: <%= Math.min((r.count/stats.totalUsers)*100,100) %>%"></div></div>
          <span class="text-neon font-mono text-sm"><%= r.count %></span>
        </div>
        <% }) %>
      </div>
    </div>
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-wide mb-4">QUICK ACTIONS</h2>
      <div class="grid grid-cols-2 gap-3">
        <a href="/events/create" class="card p-4 text-center hover:border-neon/40 transition-all"><div class="text-2xl mb-2">📅</div><p class="text-sm text-gray-300">Create Event</p></a>
        <a href="/hackathons/create" class="card p-4 text-center hover:border-neon/40 transition-all"><div class="text-2xl mb-2">⚡</div><p class="text-sm text-gray-300">Create Hackathon</p></a>
        <a href="/courses/create" class="card p-4 text-center hover:border-neon/40 transition-all"><div class="text-2xl mb-2">📚</div><p class="text-sm text-gray-300">Create Course</p></a>
        <a href="/admin/activity" class="card p-4 text-center hover:border-neon/40 transition-all"><div class="text-2xl mb-2">📋</div><p class="text-sm text-gray-300">Activity Logs</p></a>
      </div>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
