<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-7xl mx-auto">
  <div class="mb-8">
    <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ DASHBOARD</p>
    <h1 class="font-display font-bold text-white text-2xl"><%= user.name.toUpperCase() %></h1>
    <span class="badge badge-neon mt-2"><%= user.role %></span>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 sm:gap-6">
    <div class="card p-6">
      <h2 class="font-display text-white text-sm font-bold mb-4">QUICK LINKS</h2>
      <div class="space-y-2">
        <a href="/events" class="sidebar-link">📅 Events</a>
        <a href="/hackathons" class="sidebar-link">⚡ Hackathons</a>
        <a href="/leaderboard" class="sidebar-link">🏆 Leaderboard</a>
        <a href="/sponsors" class="sidebar-link">🤝 Sponsors</a>
      </div>
    </div>
    <div class="card p-6">
      <h2 class="font-display text-white text-sm font-bold mb-4">PROFILE</h2>
      <div class="space-y-2 text-sm text-gray-400">
        <p><span class="text-neon">Name:</span> <%= user.name %></p>
        <p><span class="text-neon">Email:</span> <%= user.email %></p>
        <p><span class="text-neon">Role:</span> <%= user.role %></p>
        <p><span class="text-neon">Points:</span> <%= user.points || 0 %></p>
      </div>
      <a href="/auth/profile" class="btn-neon text-xs mt-4 inline-block">EDIT PROFILE</a>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
