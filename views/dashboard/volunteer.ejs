<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ VOLUNTEER PORTAL</p>
      <h1 class="font-display font-bold text-white text-2xl">WELCOME, <%= user.name.toUpperCase().split(' ')[0] %></h1>
    </div>
    <a href="/attendance/volunteer" class="btn-neon-solid text-sm">📍 ATTENDANCE PANEL</a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <div class="card p-5 text-center">
      <p class="text-3xl font-display font-black neon-text"><%= myAttendanceMarked %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">ATTENDANCE MARKED</p>
    </div>
    <div class="card p-5 text-center">
      <p class="text-3xl font-display font-black text-white"><%= todayEvents.length %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">ACTIVE EVENTS</p>
    </div>
  </div>
  <div class="card p-6">
    <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">TODAY'S EVENTS</h2>
    <% if (todayEvents.length === 0) { %>
    <p class="text-gray-500 text-sm text-center py-6">No active events right now</p>
    <% } else { %>
    <div class="space-y-3">
      <% todayEvents.forEach(event => { %>
      <div class="flex items-center justify-between p-4 rounded bg-dark-hover">
        <div>
          <p class="text-white font-semibold"><%= event.title %></p>
          <p class="text-xs text-gray-500 font-mono"><%= new Date(event.startDate).toLocaleString('en-IN',{hour:'2-digit',minute:'2-digit'}) %> – <%= new Date(event.endDate).toLocaleString('en-IN',{hour:'2-digit',minute:'2-digit'}) %></p>
        </div>
        <div class="flex gap-2 items-center">
          <span class="text-xs text-gray-400 font-mono"><%= event.participants.filter(p=>p.attended).length %>/<%= event.participants.length %></span>
          <a href="/events/<%= event._id %>/participants" class="btn-neon text-xs px-4 py-2">MANAGE</a>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
  <div class="mt-6 grid grid-cols-2 gap-4">
    <a href="/events" class="card p-5 text-center hover:border-neon/30 transition-all"><p class="text-2xl mb-2">📅</p><p class="text-sm text-gray-300">All Events</p></a>
    <a href="/attendance/my" class="card p-5 text-center hover:border-neon/30 transition-all"><p class="text-2xl mb-2">📊</p><p class="text-sm text-gray-300">My Attendance</p></a>
  </div>
</main>
<%- include('../partials/footer') %>
