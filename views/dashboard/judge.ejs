<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-6xl mx-auto">
  <div class="mb-8">
    <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ JUDGE PORTAL</p>
    <h1 class="font-display font-bold text-white text-2xl">WELCOME, <%= user.name.toUpperCase().split(' ')[0] %></h1>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <div class="card p-5 text-center">
      <p class="text-3xl font-display font-black neon-text"><%= myHackathons.length %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">ASSIGNED HACKATHONS</p>
    </div>
    <div class="card p-5 text-center">
      <p class="text-3xl font-display font-black text-white"><%= pendingSubmissions.length %></p>
      <p class="text-xs text-gray-500 font-mono mt-1">PENDING EVALUATIONS</p>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">MY HACKATHONS</h2>
      <% if (myHackathons.length === 0) { %>
      <p class="text-gray-500 text-sm text-center py-6">No hackathons assigned yet</p>
      <% } else { %>
      <div class="space-y-3">
        <% myHackathons.forEach(h => { %>
        <a href="/hackathons/<%= h._id %>/leaderboard" class="flex items-center justify-between p-3 rounded bg-dark-hover block">
          <div><p class="text-white font-semibold"><%= h.title %></p><span class="badge badge-neon"><%= h.status.replace(/_/g,' ') %></span></div>
          <span class="text-neon text-xs font-mono">JUDGE →</span>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>
    <div class="card p-6">
      <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">PENDING SUBMISSIONS</h2>
      <% if (pendingSubmissions.length === 0) { %>
      <p class="text-gray-500 text-sm text-center py-6">All submissions scored!</p>
      <% } else { %>
      <div class="space-y-3">
        <% pendingSubmissions.forEach(sub => { %>
        <div class="p-3 rounded bg-dark-hover">
          <p class="text-white font-semibold text-sm"><%= sub.projectTitle %></p>
          <p class="text-xs text-gray-500">Team: <%= sub.team?.name %></p>
          <div class="flex gap-2 mt-2">
            <a href="<%= sub.githubLink %>" target="_blank" class="text-xs text-neon hover:underline">GitHub ↗</a>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
