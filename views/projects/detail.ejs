<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-5xl mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <a href="/projects" class="text-gray-500 text-sm hover:text-neon font-mono">← PROJECT SHOWCASE</a>
    <% const canEdit = currentUser && (project.createdBy?._id?.toString()===currentUser._id?.toString() || ['superadmin','admin'].includes(currentUser.role)); %>
    <% if (canEdit) { %>
    <div class="flex gap-2">
      <a href="/projects/<%= project._id %>/edit" class="btn-neon text-sm">EDIT</a>
      <form action="/projects/<%= project._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this project?')">
        <button type="submit" class="btn-neon text-sm border-red-500/40 text-red-400">DELETE</button>
      </form>
    </div>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Header Card -->
      <div class="card overflow-hidden">
        <% if (project.thumbnail && !project.thumbnail.includes('project-default')) { %>
        <div class="w-full h-64 overflow-hidden">
          <img src="<%= project.thumbnail %>" alt="<%= project.title %>" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML=''">
        </div>
        <% } %>
        <div class="p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="badge badge-neon"><%= project.category.replace('_',' ') %></span>
            <% if (project.isFeatured) { %><span class="badge badge-yellow">⭐ FEATURED</span><% } %>
            <% if (project.hackathon) { %><span class="badge badge-purple">⚡ Hackathon Project</span><% } %>
          </div>
          <h1 class="font-display font-bold text-white text-3xl mb-3"><%= project.title %></h1>
          <p class="text-gray-400 leading-relaxed text-lg"><%= project.description %></p>

          <% if (project.techStack?.length) { %>
          <div class="flex flex-wrap gap-2 mt-4">
            <% project.techStack.forEach(t => { %><span class="badge badge-gray">#<%= t %></span><% }) %>
          </div>
          <% } %>

          <!-- Action Buttons -->
          <div class="flex flex-wrap gap-3 mt-6">
            <% if (project.githubLink) { %>
            <a href="<%= project.githubLink %>" target="_blank" class="btn-neon text-sm px-5 py-2 flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
            <% } %>
            <% if (project.liveLink) { %>
            <a href="<%= project.liveLink %>" target="_blank" class="btn-neon-solid text-sm px-5 py-2">🚀 Live Demo</a>
            <% } %>
            <!-- Like Button -->
            <button id="like-btn" onclick="toggleLike('<%= project._id %>')" class="btn-neon text-sm px-5 py-2 flex items-center gap-2 <%= isLiked ? 'bg-red-500/10 border-red-500/40 text-red-400' : '' %>">
              <span id="like-icon"><%= isLiked ? '❤️' : '🤍' %></span>
              <span id="like-count"><%= project.likes %></span>
            </button>
          </div>
        </div>
      </div>

      <!-- Demo Video -->
      <% if (project.demoVideo) { %>
      <div class="card p-6">
        <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">📹 DEMO VIDEO</h2>
        <%
          let ytId = '';
          if (project.demoVideo.includes('youtube.com/watch')) ytId = project.demoVideo.split('v=')[1]?.split('&')[0];
          else if (project.demoVideo.includes('youtu.be/')) ytId = project.demoVideo.split('youtu.be/')[1]?.split('?')[0];
        %>
        <% if (ytId) { %>
        <div class="aspect-video rounded-lg overflow-hidden border border-dark-border">
          <iframe src="https://www.youtube.com/embed/<%= ytId %>" class="w-full h-full" allowfullscreen></iframe>
        </div>
        <% } else { %>
        <a href="<%= project.demoVideo %>" target="_blank" class="btn-neon text-sm">▶ Watch Demo ↗</a>
        <% } %>
      </div>
      <% } %>

      <!-- Long Description -->
      <% if (project.longDescription) { %>
      <div class="card p-6">
        <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">ABOUT THIS PROJECT</h2>
        <div class="text-gray-300 leading-relaxed text-sm whitespace-pre-line"><%= project.longDescription %></div>
      </div>
      <% } %>

      <!-- Related Projects -->
      <% if (related.length > 0) { %>
      <div class="card p-6">
        <h2 class="font-display text-white font-bold text-sm tracking-widest mb-4">SIMILAR PROJECTS</h2>
        <div class="space-y-3">
          <% related.forEach(r => { %>
          <a href="/projects/<%= r._id %>" class="flex items-center gap-3 p-3 rounded hover:bg-dark-hover transition-colors block">
            <span class="text-xl"><%= r.category==='web'?'🌐':r.category==='mobile'?'📱':r.category==='ai_ml'?'🤖':'💡' %></span>
            <div><p class="text-white text-sm font-semibold"><%= r.title %></p><p class="text-gray-500 text-xs"><%= (r.authors||[]).map(a=>a.name).join(', ') %></p></div>
            <span class="text-neon text-xs ml-auto">❤ <%= r.likes %></span>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-4">

      <!-- Team / Authors -->
      <div class="card p-5">
        <h3 class="font-display text-neon text-xs tracking-widest font-bold mb-4">BUILT BY</h3>
        <div class="space-y-3">
          <% if (project.authors?.length > 0) { %>
            <% project.authors.forEach(author => { %>
            <div class="flex items-center gap-3">
              <img src="<%= author.avatar||'/images/default-avatar.png' %>" class="w-9 h-9 rounded-full border border-dark-border" onerror="this.src='/images/default-avatar.png'">
              <div class="flex-1 min-w-0">
                <p class="text-white text-sm font-semibold"><%= author.name %></p>
                <div class="flex gap-2 mt-0.5">
                  <% if (author.github) { %><a href="<%= author.github %>" target="_blank" class="text-xs text-gray-500 hover:text-neon">GH</a><% } %>
                  <% if (author.linkedin) { %><a href="<%= author.linkedin %>" target="_blank" class="text-xs text-gray-500 hover:text-neon">in</a><% } %>
                </div>
              </div>
            </div>
            <% }) %>
          <% } %>
          <% if (project.authorNames?.length > 0) { %>
            <% project.authorNames.forEach(name => { %>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full border border-dark-border bg-dark-hover flex items-center justify-center text-neon font-bold text-sm"><%= name[0].toUpperCase() %></div>
              <p class="text-white text-sm"><%= name %></p>
            </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <!-- Stats -->
      <div class="card p-5">
        <h3 class="font-display text-neon text-xs tracking-widest font-bold mb-3">PROJECT STATS</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-500">Views</span><span class="text-white font-mono"><%= project.views %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Likes</span><span class="text-neon font-mono"><%= project.likes %></span></div>
          <div class="flex justify-between"><span class="text-gray-500">Submitted</span><span class="text-white text-xs font-mono"><%= new Date(project.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span></div>
          <% if (project.hackathon) { %><div class="flex justify-between"><span class="text-gray-500">Hackathon</span><a href="/hackathons/<%= project.hackathon._id %>" class="text-neon text-xs hover:underline"><%= project.hackathon.title %></a></div><% } %>
        </div>
      </div>

      <!-- Tags -->
      <% if (project.tags?.length) { %>
      <div class="card p-5">
        <h3 class="font-display text-neon text-xs tracking-widest font-bold mb-3">TAGS</h3>
        <div class="flex flex-wrap gap-2">
          <% project.tags.forEach(t => { %><span class="badge badge-gray text-xs">#<%= t %></span><% }) %>
        </div>
      </div>
      <% } %>

      <!-- Admin: Feature toggle -->
      <% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
      <div class="card p-4">
        <h3 class="font-display text-neon text-xs tracking-widest font-bold mb-3">ADMIN CONTROLS</h3>
        <form action="/projects/<%= project._id %>?_method=PUT" method="POST" class="space-y-3">
          <input type="hidden" name="title" value="<%= project.title %>" />
          <input type="hidden" name="description" value="<%= project.description %>" />
          <input type="hidden" name="category" value="<%= project.category %>" />
          <div>
            <label class="block text-xs text-gray-400 mb-1 font-mono">STATUS</label>
            <select name="status" class="input-dark text-xs">
              <% ['draft','published','featured'].forEach(s => { %><option value="<%= s %>" <%= project.status===s?'selected':'' %>><%= s.toUpperCase() %></option><% }) %>
            </select>
          </div>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="isFeatured" <%= project.isFeatured?'checked':'' %> class="accent-neon" />
            <span class="text-gray-400 text-xs">Featured on homepage</span>
          </label>
          <button type="submit" class="btn-neon-solid w-full py-1.5 text-xs font-display tracking-widest">UPDATE STATUS</button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</main>

<script>
async function toggleLike(projectId) {
  <% if (!currentUser) { %>window.location.href='/auth/login'; return;<% } %>
  try {
    const r = await fetch(`/projects/${projectId}/like`, { method: 'POST' });
    const d = await r.json();
    if (d.success) {
      document.getElementById('like-count').textContent = d.likes;
      document.getElementById('like-icon').textContent = d.liked ? '❤️' : '🤍';
      const btn = document.getElementById('like-btn');
      btn.className = btn.className.replace(/text-red-400|border-red-500\/40|bg-red-500\/10/g, '').trim();
      if (d.liked) btn.className += ' bg-red-500/10 border-red-500/40 text-red-400';
    }
  } catch(e) { console.error(e); }
}
</script>
<%- include('../partials/footer') %>
