<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-3xl mx-auto">
  <div class="mb-6"><a href="/events" class="text-gray-500 text-sm hover:text-neon font-mono">← BACK</a></div>
  <div class="card p-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-neon to-transparent"></div>
    <h1 class="font-display font-bold text-white text-2xl tracking-widest mb-8"><%= event ? 'EDIT EVENT' : 'CREATE EVENT' %></h1>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-500/10 border border-red-500/30 text-red-400 px-4 py-3 rounded text-sm mb-6">⚠ <%= error %></div>
    <% } %>
    <form action="<%= event ? '/events/'+event._id+'?_method=PUT' : '/events' %>" method="POST" class="space-y-5">
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">EVENT TITLE *</label>
        <input type="text" name="title" required value="<%= event?.title||'' %>" placeholder="Intro to Web Dev Workshop" class="input-dark" />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">DESCRIPTION *</label>
        <textarea name="description" required rows="4" placeholder="Describe the event..." class="input-dark resize-none"><%= event?.description||'' %></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">TYPE</label>
          <select name="type" class="input-dark">
            <% ['workshop','seminar','webinar','competition','meetup','live_class','other'].forEach(t => { %>
            <option value="<%= t %>" <%= event?.type===t?'selected':'' %>><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">STATUS</label>
          <select name="status" class="input-dark">
            <% ['draft','published','ongoing','completed','cancelled'].forEach(s => { %>
            <option value="<%= s %>" <%= event?.status===s?'selected':'' %>><%= s %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">START DATE & TIME *</label>
          <input type="datetime-local" name="startDate" required value="<%= event?.startDate ? new Date(event.startDate).toISOString().slice(0,16) : '' %>" class="input-dark" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">END DATE & TIME *</label>
          <input type="datetime-local" name="endDate" required value="<%= event?.endDate ? new Date(event.endDate).toISOString().slice(0,16) : '' %>" class="input-dark" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">VENUE</label>
          <input type="text" name="venue" value="<%= event?.venue||'' %>" placeholder="Room 101 / Online" class="input-dark" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">MAX PARTICIPANTS</label>
          <input type="number" name="maxParticipants" value="<%= event?.maxParticipants||100 %>" min="1" class="input-dark" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">MEETING LINK (if virtual)</label>
        <input type="url" name="meetingLink" value="<%= event?.meetingLink||'' %>" placeholder="https://meet.google.com/..." class="input-dark" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">POINTS REWARD</label>
          <input type="number" name="pointsReward" value="<%= event?.pointsReward||10 %>" min="0" class="input-dark" />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">REGISTRATION DEADLINE</label>
          <input type="datetime-local" name="registrationDeadline" value="<%= event?.registrationDeadline ? new Date(event.registrationDeadline).toISOString().slice(0,16) : '' %>" class="input-dark" />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-2 font-mono tracking-wider">TAGS (comma separated)</label>
        <input type="text" name="tags" value="<%= event?.tags?.join(',')||'' %>" placeholder="javascript, web, beginner" class="input-dark" />
      </div>
      <div class="flex gap-6">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="isVirtual" <%= event?.isVirtual?'checked':'' %> class="accent-neon" />
          <span class="text-gray-400 text-sm">Virtual Event</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="isPublic" <%= event?.isPublic!==false?'checked':'' %> class="accent-neon" />
          <span class="text-gray-400 text-sm">Public (External users can register)</span>
        </label>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-neon-solid px-8 py-3 font-display tracking-widest text-sm"><%= event ? 'UPDATE' : 'CREATE' %> EVENT</button>
        <a href="/events" class="btn-neon px-8 py-3 font-display tracking-widest text-sm">CANCEL</a>
      </div>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
