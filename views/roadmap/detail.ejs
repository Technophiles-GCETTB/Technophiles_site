<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-4xl mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <a href="/roadmaps" class="text-gray-500 text-sm hover:text-neon font-mono">← ALL ROADMAPS</a>
    <% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
    <div class="flex gap-2">
      <a href="/roadmaps/<%= roadmap._id %>/edit" class="btn-neon text-sm">EDIT</a>
      <form action="/roadmaps/<%= roadmap._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete?')">
        <button type="submit" class="btn-neon text-sm text-red-400 border-red-500/40">DELETE</button>
      </form>
    </div>
    <% } %>
  </div>

  <!-- Header -->
  <div class="card p-8 mb-8 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1" style="background: linear-gradient(90deg, transparent, <%= roadmap.color || '#39FF14' %>, transparent)"></div>
    <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-5">
      <% if (roadmap.icon) { %><span class="text-5xl flex-shrink-0"><%= roadmap.icon %></span><% } %>
      <div>
        <% if (roadmap.category) { %><span class="badge badge-gray text-xs mb-2 inline-block"><%= roadmap.category %></span><% } %>
        <h1 class="font-display font-bold text-white text-3xl mb-2"><%= roadmap.title %></h1>
        <% if (roadmap.description) { %><p class="text-gray-400 leading-relaxed"><%= roadmap.description %></p><% } %>
        <p class="text-gray-500 text-sm mt-3 font-mono"><%= roadmap.steps?.length || 0 %> steps in this roadmap</p>
      </div>
    </div>
  </div>

  <!-- Steps -->
  <div class="space-y-4">
    <% if (roadmap.steps && roadmap.steps.length > 0) { %>
    <% roadmap.steps.forEach((step, i) => { %>
    <%
      const courseId = step.course?._id?.toString();
      const progress = courseId && userProgress[courseId];
      const isCompleted = progress?.isCompleted;
      const isInProgress = progress && !progress.isCompleted && progress.progressPercent > 0;
    %>
    <div class="card p-6 relative overflow-hidden <%= isCompleted ? 'border-neon/30' : '' %>">
      <% if (isCompleted) { %>
      <div class="absolute top-3 right-3 text-neon text-lg">✓</div>
      <% } %>
      <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-5">
        <!-- Step number -->
        <div class="w-10 h-10 rounded-full border-2 flex-shrink-0 flex items-center justify-center font-display font-bold text-sm mt-1"
          style="border-color:<%= isCompleted ? roadmap.color||'#39FF14' : '#1a1a1a' %>;
                 color:<%= isCompleted ? roadmap.color||'#39FF14' : '#555' %>;
                 background:<%= isCompleted ? (roadmap.color||'#39FF14')+'15' : 'transparent' %>">
          <%= i + 1 %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 mb-1 flex-wrap">
            <h3 class="text-white font-bold text-lg"><%= step.title %></h3>
            <% if (step.isOptional) { %><span class="badge badge-gray text-xs">OPTIONAL</span><% } %>
            <% if (isCompleted) { %><span class="badge badge-neon text-xs">COMPLETED</span>
            <% } else if (isInProgress) { %><span class="badge badge-yellow text-xs"><%= progress.progressPercent %>% done</span><% } %>
          </div>
          <% if (step.description) { %><p class="text-gray-400 text-sm mb-3 leading-relaxed"><%= step.description %></p><% } %>

          <!-- Linked course -->
          <% if (step.course) { %>
          <div class="flex items-center gap-3 p-3 bg-dark-hover rounded border border-dark-border">
            <span class="text-2xl">
              <%= step.course.category === 'web_dev' ? '🌐' : step.course.category === 'dsa' ? '🧩' : step.course.category === 'ai_ml' ? '🤖' : '📚' %>
            </span>
            <div class="flex-1 min-w-0">
              <p class="text-white font-semibold text-sm"><%= step.course.title %></p>
              <div class="flex items-center gap-2 mt-1">
                <span class="badge badge-gray text-xs"><%= step.course.category?.replace('_',' ') %></span>
                <span class="badge badge-gray text-xs"><%= step.course.level %></span>
              </div>
              <% if (isInProgress) { %>
              <div class="progress-bar mt-2 w-32"><div class="progress-fill" style="width:<%= progress.progressPercent %>%"></div></div>
              <% } %>
            </div>
            <% if (currentUser) { %>
              <% if (isCompleted) { %>
              <span class="text-neon text-sm font-mono">✓ DONE</span>
              <% } else if (isInProgress) { %>
              <a href="/courses/<%= step.course._id %>/learn" class="btn-neon text-xs px-4 py-1.5">CONTINUE →</a>
              <% } else { %>
              <a href="/courses/<%= step.course._id %>" class="btn-neon-solid text-xs px-4 py-1.5">START →</a>
              <% } %>
            <% } else { %>
            <a href="/courses/<%= step.course._id %>" class="btn-neon text-xs px-4 py-1.5">VIEW →</a>
            <% } %>
          </div>
          <% } %>

          <!-- External resources -->
          <% if (step.resources && step.resources.length > 0) { %>
          <div class="mt-3 flex flex-wrap gap-2">
            <% step.resources.forEach(r => { %>
            <a href="<%= r.url %>" target="_blank" class="flex items-center gap-1 text-xs text-gray-400 hover:text-neon border border-dark-border rounded px-2 py-1 transition-colors">🔗 <%= r.title %></a>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <!-- Connector line between steps -->
    <% if (i < roadmap.steps.length - 1) { %>
    <div class="flex justify-center"><div class="w-px h-4" style="background:<%= roadmap.color||'#39FF14' %>30"></div></div>
    <% } %>
    <% }) %>
    <% } %>
  </div>

  <!-- Not logged in nudge -->
  <% if (!currentUser) { %>
  <div class="card p-6 mt-8 text-center border-neon/20 bg-neon/5">
    <p class="text-gray-300 mb-3">Sign in to track your progress through this roadmap</p>
    <a href="/auth/login" class="btn-neon-solid text-sm px-8 py-2">LOGIN TO TRACK PROGRESS</a>
  </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
