<%- include('../partials/head') %>
<%- include('../partials/navbar') %>
<main class="pt-20 md:pt-24 pb-10 md:pb-16 px-3 sm:px-4 max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-10">
    <div>
      <p class="text-neon font-mono text-xs tracking-widest mb-1">◈ STRUCTURED PATHS</p>
      <h1 class="font-display font-bold text-white text-2xl">LEARNING ROADMAPS</h1>
    </div>
    <% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
    <a href="/roadmaps/create" class="btn-neon-solid text-sm">+ CREATE ROADMAP</a>
    <% } %>
  </div>

  <% if (roadmaps.length === 0) { %>
  <div class="text-center py-20 card">
    <p class="text-5xl mb-4">🗺</p>
    <p class="text-gray-400 text-lg mb-3">No roadmaps yet</p>
    <% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
    <a href="/roadmaps/create" class="btn-neon-solid text-sm">Create First Roadmap</a>
    <% } %>
  </div>
  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 sm:gap-6">
    <% roadmaps.forEach(rm => { %>
    <div class="card p-6 relative overflow-hidden group">
      <!-- Color accent bar -->
      <div class="absolute top-0 left-0 w-1 h-full" style="background: <%= rm.color || '#39FF14' %>"></div>
      <div class="pl-3">
        <div class="flex items-start justify-between mb-4">
          <div class="flex items-center gap-3">
            <% if (rm.icon) { %><span class="text-3xl"><%= rm.icon %></span><% } %>
            <div>
              <h3 class="text-white font-bold text-lg group-hover:text-neon transition-colors"><%= rm.title %></h3>
              <% if (rm.category) { %><span class="badge badge-gray text-xs"><%= rm.category %></span><% } %>
            </div>
          </div>
          <% if (currentUser && ['superadmin','admin'].includes(currentUser.role)) { %>
          <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
            <a href="/roadmaps/<%= rm._id %>/edit" class="text-xs text-neon hover:underline font-mono">EDIT</a>
            <form action="/roadmaps/<%= rm._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete roadmap?')">
              <button class="text-xs text-red-400 hover:text-red-300 font-mono">DEL</button>
            </form>
          </div>
          <% } %>
        </div>
        <% if (rm.description) { %><p class="text-gray-400 text-sm mb-4 leading-relaxed"><%= rm.description %></p><% } %>
        <% if (rm.steps && rm.steps.length > 0) { %>
        <div class="space-y-2 mb-4">
          <% rm.steps.slice(0,4).forEach((step, i) => { %>
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full border-2 flex-shrink-0 flex items-center justify-center text-xs font-mono mt-0.5" style="border-color:<%= rm.color||'#39FF14' %>;color:<%= rm.color||'#39FF14' %>"><%= i+1 %></div>
            <div>
              <p class="text-gray-300 text-sm"><%= step.title %></p>
              <% if (step.course) { %><p class="text-gray-500 text-xs font-mono"><%= step.course.title %></p><% } %>
            </div>
          </div>
          <% }) %>
          <% if (rm.steps.length > 4) { %>
          <p class="text-gray-600 text-xs pl-8">+<%= rm.steps.length - 4 %> more steps</p>
          <% } %>
        </div>
        <% } %>
        <a href="/roadmaps/<%= rm._id %>" class="btn-neon text-xs px-5 py-1.5 inline-block font-mono">VIEW ROADMAP →</a>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</main>
<%- include('../partials/footer') %>
